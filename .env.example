# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sora2
# Optional: true/false. Set true for managed DB with SSL requirements.
DATABASE_SSL=false

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_USE_WEBHOOK=true
# Full public HTTPS URL used in setWebhook (must match your domain)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook/sora2
# Extra security header token (any long random string)
TELEGRAM_WEBHOOK_SECRET=replace_with_long_random_secret
# Optional explicit path on this app; should match path part in TELEGRAM_WEBHOOK_URL
TELEGRAM_WEBHOOK_PATH=/telegram/webhook/sora2

# Web admin
WEB_HOST=0.0.0.0
WEB_PORT=3000
# Public URL used in bot messages (project/settings links)
WEB_PUBLIC_URL=https://your-domain.com

# OpenRouter (Gemini Flash & Pro)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL_FLASH=google/gemini-2.5-flash
OPENROUTER_MODEL_FLASH_FALLBACK=google/gemini-2.5-pro
OPENROUTER_MODEL_PRO=google/gemini-2.5-pro
OPENROUTER_PROVIDER_ORDER=google-vertex,google-ai-studio
OPENROUTER_ALLOW_FALLBACKS=true

# Kie.ai (Sora 2 & Veo 3.1)
KIE_AI_API_KEY=your_kie_api_key

# WaveSpeedAI fallback for Sora 2
WAVESPEED_API_KEY=your_wavespeed_api_key
WAVESPEED_SORA2_DURATION=4

# Yandex Disk
YANDEX_TOKEN=your_yandex_disk_oauth_token

# RapidAPI (Instagram Social API)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=instagram-social-api.p.rapidapi.com
IG_API_BASE=https://instagram-social-api.p.rapidapi.com/v1/info
